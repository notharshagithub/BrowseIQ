# xAI / Groq API Configuration
# If using xAI Grok: set base to https://api.x.ai/v1 and model to grok-2-vision-1212 (with xai- API key)
# If using Groq: set base to https://api.groq.com/openai/v1 and model to llama-3.3-70b-versatile (with gsk_ API key)
XAI_API_KEY=your_xai_or_groq_api_key_here
XAI_API_BASE=https://api.groq.com/openai/v1
XAI_MODEL=llama-3.3-70b-versatile

# Automation target
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Browser and Loop configuration
HEADLESS=True
MAX_STEPS=10

# Directories
SCREENSHOTS_DIR=screenshots
LOGS_DIR=logs

# Remote Browser connection (required for Vercel Serverless deployments)
# CONNECT_TO_BROWSER_URL=wss://chrome.browserless.io?token=your_browserless_token_here
